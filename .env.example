# Copy to .env. The reasoning LLM is chosen by which of these is set (top wins):

# 1. Self-hosted model server (recommended for the exam) — your DataLab box
#    running model_server/server.py, exposed via a public URL. See model_server/README.md.
MODEL_SERVER_URL=
MODEL_SERVER_KEY=

# 2. Free Hugging Face token (https://huggingface.co/settings/tokens) — used by
#    src/utils.get_llm() to call Llama-3.1-8B via HF Inference Providers.
#    NOTE: free tier has a small monthly credit; can hit HTTP 402 when depleted.
HUGGINGFACEHUB_API_TOKEN=

# 3. If none of the above is set, the pipeline falls back to a local
#    Qwen2.5-0.5B-Instruct model (offline, weak, but never fails).
